www.YOUR_DOMAIN {
	header {
		Strict-Transport-Security "max-age=31536000"
		-Server
	}

	redir https://YOUR_DOMAIN{uri} permanent
}

YOUR_DOMAIN {
	encode zstd gzip

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=()"
		Strict-Transport-Security "max-age=31536000"
		-Server
	}

	@portfolioCsp not path /cases/horseschool/live/*
	header @portfolioCsp Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' https://mc.yandex.ru https://yastatic.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://mc.yandex.ru https://mc.yandex.az https://mc.yandex.by https://mc.yandex.co.il https://mc.yandex.com https://mc.yandex.com.am https://mc.yandex.com.ge https://mc.yandex.com.tr https://mc.yandex.ee https://mc.yandex.fr https://mc.yandex.kg https://mc.yandex.kz https://mc.yandex.lt https://mc.yandex.lv https://mc.yandex.md https://mc.yandex.tj https://mc.yandex.tm https://mc.yandex.uz https://mc.webvisor.org https://mc.webvisor.com; font-src 'self' data:; media-src 'self' blob:; connect-src 'self' https://mc.yandex.ru https://mc.yandex.az https://mc.yandex.by https://mc.yandex.co.il https://mc.yandex.com https://mc.yandex.com.am https://mc.yandex.com.ge https://mc.yandex.com.tr https://mc.yandex.ee https://mc.yandex.fr https://mc.yandex.kg https://mc.yandex.kz https://mc.yandex.lt https://mc.yandex.lv https://mc.yandex.md https://mc.yandex.tj https://mc.yandex.tm https://mc.yandex.uz https://mc.webvisor.org https://mc.webvisor.com; worker-src 'self' blob:; frame-src 'self' https://mc.yandex.ru; manifest-src 'self'; upgrade-insecure-requests"

	@horseSchoolCsp path /cases/horseschool/live/*
	header @horseSchoolCsp Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://code.iconify.design; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://images.pexels.com; font-src 'self' data: https://fonts.gstatic.com; media-src 'self' blob:; connect-src 'self'; worker-src 'self' blob:; frame-src 'self'; manifest-src 'self'; upgrade-insecure-requests"

	@contact path /api/contact
	handle @contact {
		reverse_proxy 127.0.0.1:3001
	}

	@health path /health
	handle @health {
		reverse_proxy 127.0.0.1:3001
	}

	handle {
		root * /var/www/portfolio/current

		@nextStatic path /_next/static/*
		header @nextStatic Cache-Control "public, max-age=31536000, immutable"

		@staticAssets {
			not path /_next/static/*
			path_regexp staticAssets \.(?:avif|css|gif|ico|jpe?g|js|mjs|mp4|png|svg|webm|webp|woff2?)$
		}
		header @staticAssets Cache-Control "public, max-age=2592000"

		@documents {
			not path /_next/static/*
			not path_regexp documentAssets \.(?:avif|css|gif|ico|jpe?g|js|mjs|mp4|png|svg|webm|webp|woff2?)$
		}
		header @documents Cache-Control "no-cache"

		try_files {path} {path}/ {path}.html
		file_server
	}
}
